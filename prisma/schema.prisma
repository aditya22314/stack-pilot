generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// We will add models (tables) here in the next sprints!

model Repository {
  id          String   @id @default(uuid())
  name        String
  status      String   @default("UPLOADED") // UPLOADED, EXTRACTED, FAILED
  storagePath String?
  sizeBytes   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
